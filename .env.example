# Copy to .env and fill in. On Vercel, set the same keys in Project Settings → Environment Variables.

DJANGO_SECRET_KEY=change-me-long-random-string
# Local: true. Production: false (on Vercel, defaults to false when VERCEL=1 if unset).
DJANGO_DEBUG=true

# Optional: comma-separated. Default allows localhost and *.vercel.app
# ALLOWED_HOSTS=localhost,127.0.0.1,.vercel.app

# Production: your HTTPS origin(s), e.g. https://my-app.vercel.app
# Or set PUBLIC_SITE_URL alone (https://...) to auto-add CSRF + M-Pesa callback base.
# CSRF_TRUSTED_ORIGINS=https://my-app.vercel.app
PUBLIC_SITE_URL=

DATABASE_URL=
CLOUDINARY_URL=

MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENVIRONMENT=sandbox
